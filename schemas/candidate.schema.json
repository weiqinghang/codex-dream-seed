{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Dream Candidate",
  "type": "object",
  "required": [
    "title",
    "kind",
    "confidence",
    "frequency",
    "scope",
    "projects",
    "task_refs",
    "observation",
    "evidence",
    "interpretation",
    "cause",
    "impact",
    "recommended_action",
    "suggested_artifact",
    "candidate_text_or_outline",
    "limits_and_counterexamples",
    "validation_plan"
  ],
  "properties": {
    "title": {"type": "string", "minLength": 1},
    "kind": {"enum": ["effective_practice", "reusable_work", "detour_improvement"]},
    "confidence": {"enum": ["low", "medium", "high"]},
    "frequency": {"enum": ["once", "repeated", "systemic"]},
    "scope": {"enum": ["session", "project", "cross_project", "global"]},
    "projects": {"type": "array", "items": {"type": "string"}},
    "task_refs": {"type": "array", "items": {"pattern": "^TASK-[0-9]{4,}$"}},
    "observation": {"type": "string"},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "interpretation": {"type": "string"},
    "cause": {"enum": ["user_instruction", "agent_behavior", "environment", "mixed", "not_applicable"]},
    "impact": {"type": "string"},
    "recommended_action": {"type": "string"},
    "suggested_artifact": {"enum": ["observation", "agents_rule", "skill", "script", "template", "checker"]},
    "candidate_text_or_outline": {"type": "string"},
    "limits_and_counterexamples": {"type": "string"},
    "validation_plan": {"type": "string"}
  },
  "additionalProperties": true
}
