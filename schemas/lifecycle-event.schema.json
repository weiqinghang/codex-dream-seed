{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-dream.local/schemas/lifecycle-event-v1.schema.json",
  "title": "Codex Dream lifecycle event V1",
  "type": "object",
  "required": ["event_id", "knowledge_id", "type", "occurred_at", "data"],
  "properties": {
    "event_id": { "type": "string", "pattern": "^EVT-[0-9]{4,}$" },
    "knowledge_id": { "type": "string", "pattern": "^KD-[0-9]{4,}$" },
    "type": { "type": "string", "minLength": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "data": { "type": "object" }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "schema_migrated" } } },
      "then": {
        "required": ["schema_version"],
        "properties": {
          "schema_version": { "const": 1 },
          "data": {
            "required": ["from_version", "to_version", "migration_id"]
          }
        }
      }
    }
  ]
}
